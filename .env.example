# ─────────────────────────────────────────────────────────────────────────────
# Aurea environment.  Copy to `.env` and fill in.   cp .env.example .env
# Nothing here is required to BOOT the platform (it runs with deterministic
# fallbacks), but the LLM features come alive once ANTHROPIC_API_KEY is set.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM (Anthropic-first) ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
# Default models per task class (override per-task in the Admin console).
AUREA_MODEL_ADVICE=claude-opus-4-8
AUREA_MODEL_NARRATIVE=claude-opus-4-8
AUREA_MODEL_CLASSIFY=claude-haiku-4-5-20251001
# Optional secondary providers (model-portable; leave blank to disable).
OPENAI_API_KEY=
AUREA_OPENAI_MODEL=gpt-4o

# ── Real market data (Conduit market-data connector) ─────────────────────────
# Default provider 'yahoo' needs no key. Options: yahoo | stooq | alphavantage
# (alphavantage requires a free key below).
AUREA_MARKETDATA_PROVIDER=yahoo
ALPHAVANTAGE_API_KEY=

# ── Database / cache (compose wires these automatically) ─────────────────────
POSTGRES_USER=aurea
POSTGRES_PASSWORD=aurea
POSTGRES_DB=aurea
POSTGRES_PORT=5432
REDIS_PORT=6379

# ── Service ports on the host ────────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ── Security ─────────────────────────────────────────────────────────────────
# CHANGE THIS in any non-local deployment. Used to sign JWTs.
AUREA_JWT_SECRET=dev-insecure-change-me-please-0123456789abcdef
AUREA_ACCESS_TOKEN_TTL_MINUTES=720

# ── Platform behaviour ───────────────────────────────────────────────────────
AUREA_ENV=local
AUREA_LOG_LEVEL=INFO
# Seed demo firm + synthetic clients on first boot.
AUREA_RUN_SEED=true
